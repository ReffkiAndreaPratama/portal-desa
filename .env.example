# ============================================================
# PORTAL DIGITAL DESA TALANG MARAP - ENVIRONMENT CONFIG
# ============================================================
# Salin file ini menjadi .env dan isi sesuai pilihan backend

# ============================================================
# PILIH BACKEND (isi salah satu)
# ============================================================
# "supabase"  → untuk deploy ke Vercel + Supabase (RECOMMENDED)
# "local"     → untuk development lokal pakai data statis
VITE_DB_PROVIDER=supabase

# ============================================================
# SUPABASE CONFIG (jika VITE_DB_PROVIDER=supabase)
# Dapatkan dari: https://supabase.com → Project Settings → API
# ============================================================
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# ADMIN CONFIG
# ============================================================
VITE_ADMIN_EMAIL=admin@desatalangmarap.id
# Password diatur di Supabase Auth dashboard

# ============================================================
# STORAGE (untuk upload foto/dokumen)
# Otomatis pakai Supabase Storage jika provider=supabase
# ============================================================
VITE_STORAGE_BUCKET=desa-assets
